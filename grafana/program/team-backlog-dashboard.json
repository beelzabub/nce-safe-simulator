        "showValue": "always",
        "fullHighlight": false,
        "legend": { "displayMode": "hidden", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
